# ─── Email (обязательно для работы форм) ──────────────────────────────────────
# Resend API Key — бесплатный аккаунт: https://resend.com (до 3 000 писем/мес)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Адрес, на который приходят все заявки с сайта
CONTACT_EMAIL=info@example.ru

# ─── SEO ──────────────────────────────────────────────────────────────────────
# Полный URL сайта без слеша в конце (используется в sitemap, robots, OG)
NEXT_PUBLIC_SITE_URL=https://example.ru

# Коды верификации для Яндекс.Вебмастер и Google Search Console (опционально)
YANDEX_VERIFICATION=
GOOGLE_VERIFICATION=
